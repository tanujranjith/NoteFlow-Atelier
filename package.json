{
  "name": "sutra",
  "version": "1.0.0",
  "description": "A local-first student, life, and work workspace: notes, tasks, calendar, focus, AP prep, college apps, and more. Runs as a single static web app.",
  "author": "Tanuj Ranjith",
  "license": "Apache-2.0",
  "homepage": "https://github.com/tanujranjith/Sutra",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tanujranjith/Sutra.git"
  },
  "bugs": {
    "url": "https://github.com/tanujranjith/Sutra/issues"
  },
  "keywords": [
    "notes",
    "productivity",
    "student",
    "local-first",
    "static",
    "no-build"
  ],
  "scripts": {
    "serve": "node scripts/serve-static.mjs",
    "check": "node scripts/smoke-check.mjs",
    "check:syntax": "node scripts/syntax-check.mjs",
    "check:roundtrip": "node scripts/round-trip-check.mjs",
    "check:versions": "node scripts/version-history-check.mjs",
    "check:rebrand": "node scripts/sutra-rebrand-check.mjs",
    "check:compat": "node scripts/sutra-compat-check.mjs",
    "check:csp": "node scripts/sutra-csp-check.mjs",
    "check:persistence": "node scripts/sutra-persistence-health-check.mjs",
    "check:modal": "node scripts/sutra-modal-a11y-check.mjs",
    "check:network": "node scripts/sutra-network-check.mjs",
    "check:encoding": "node scripts/sutra-encoding-check.mjs",
    "check:responsive": "node scripts/sutra-responsive-check.mjs",
    "check:brand": "node scripts/sutra-brand-assets-check.mjs",
    "check:docbg": "node scripts/sutra-docbg-check.mjs",
    "check:all": "node scripts/syntax-check.mjs && node scripts/smoke-check.mjs && node scripts/round-trip-check.mjs && node scripts/version-history-check.mjs && node scripts/sutra-rebrand-check.mjs && node scripts/sutra-compat-check.mjs && node scripts/sutra-csp-check.mjs && node scripts/sutra-persistence-health-check.mjs && node scripts/sutra-modal-a11y-check.mjs && node scripts/sutra-network-check.mjs && node scripts/sutra-encoding-check.mjs && node scripts/sutra-responsive-check.mjs && node scripts/sutra-brand-assets-check.mjs && node scripts/sutra-docbg-check.mjs",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "build:deploy": "node scripts/build-deploy-artifact.mjs",
    "check:deploy": "node scripts/sutra-deploy-artifact-check.mjs",
    "check:live": "node scripts/sutra-live-smoke-check.mjs",
    "bench:heavy": "playwright test --config=playwright.bench.config.mjs"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "playwright": "^1.60.0"
  }
}
